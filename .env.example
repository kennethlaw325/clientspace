# ============================================================
# ClientSpace 環境變數範例
# 複製此檔案為 .env.local 並填入實際值
# 切勿將 .env.local 提交到版本控制
# ============================================================

# ------------------------------------------------------------
# Supabase
# 從 Supabase Dashboard > Project Settings > API 取得
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# Stripe
# 從 Stripe Dashboard > Developers > API Keys 取得
# 測試模式用 sk_test_... / pk_test_...
# 生產模式用 sk_live_... / pk_live_...
# ------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
STRIPE_SECRET_KEY=sk_live_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Stripe Price IDs
# 從 Stripe Dashboard > Products 取得對應 Price ID
STRIPE_STARTER_PRICE_ID=price_your-starter-price-id
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# ------------------------------------------------------------
# Resend（電子郵件服務）
# 從 Resend Dashboard > API Keys 取得
# ------------------------------------------------------------
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=ClientSpace

# ------------------------------------------------------------
# 應用程式設定
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ------------------------------------------------------------
# 可選：Analytics（如使用）
# ------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
